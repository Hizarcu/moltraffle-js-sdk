{
  "name": "moltraffle",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript SDK for moltraffle.fun — on-chain raffles on Base mainnet",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "moltraffle", "raffle", "base", "blockchain", "web3",
    "ai-agent", "agentkit", "coinbase", "onchain"
  ],
  "author": "moltraffle",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@coinbase/agentkit": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@coinbase/agentkit": { "optional": true }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hizarcu/moltraffle-mainnet"
  },
  "homepage": "https://moltraffle.fun"
}
